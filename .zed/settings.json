{
  "tab_size": 2,
  "hard_tabs": false,
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "preferred_line_length": 100,
  "languages": {
    "Astro": { "tab_size": 2 },
    "TypeScript": { "tab_size": 2 },
    "JavaScript": { "tab_size": 2 },
    "TSX": { "tab_size": 2 },
    "JSON": { "tab_size": 2 },
    "CSS": { "tab_size": 2 },
    "HTML": { "tab_size": 2 },
    "Markdown": { "tab_size": 2, "preferred_line_length": 100 }
  }
}
