---
const features = [
  {
    accent: "amber",
    title: "Office dashboard",
    body: "Job intake, dispatch, customers, invoicing, reporting. Everything the office needs without leaving the browser tab.",
  },
  {
    accent: "cyan",
    title: "Driver PWA",
    body: "Daily run sheet, DVSA-compliant walk-around checks, proof of delivery, signature and photo capture — on any phone.",
  },
  {
    accent: "amber",
    title: "Yard view",
    body: "Weighbridge tickets, gate management, container tracking. Designed for a touchscreen on a counter.",
  },
  {
    accent: "cyan",
    title: "Maintenance",
    body: "Workshop logs defects, schedules repairs, closes the loop with drivers. Vehicles automatically flagged off-road when needed.",
  },
  {
    accent: "amber",
    title: "Automated compliance",
    body: "Waste Transfer Notes and Weighbridge Tickets generated as PDFs without a single re-typed field.",
  },
  {
    accent: "cyan",
    title: "Customer portal",
    body: "Customers raise jobs from their own website, see live status, settle invoices. Less phone, more visibility.",
  },
];
---

<section id="product" class="bg-[color:var(--color-offwhite)] border-y border-[color:var(--color-mist)]">
  <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-cyan)]">What you get</p>
      <h2 class="mt-3 font-[family-name:var(--font-display)] font-extrabold text-3xl md:text-4xl text-[color:var(--color-graphite)] tracking-tight">
        The whole operational loop, in one product.
      </h2>
      <p class="mt-4 text-[color:var(--color-slate)] text-lg">
        Drivers, yard staff, mechanics and office all share one Supabase-backed database with
        role-based access. Live updates everywhere. An append-only audit trail for regulated workflows.
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <article class="group relative rounded-2xl bg-white p-7 border border-[color:var(--color-mist)] hover:border-[color:var(--color-graphite)] transition-colors">
          <div class={`inline-flex h-10 w-10 items-center justify-center rounded-lg ${
            f.accent === "amber"
              ? "bg-[color:var(--color-amber)]/15 text-[color:var(--color-amber)]"
              : "bg-[color:var(--color-cyan)]/15 text-[color:var(--color-cyan)]"
          }`}>
            <span class="block h-3 w-3 rounded-sm" style={`background-color: ${f.accent === "amber" ? "#FF8A00" : "#0098C7"}`}></span>
          </div>
          <h3 class="mt-5 font-[family-name:var(--font-display)] font-bold text-xl text-[color:var(--color-graphite)]">{f.title}</h3>
          <p class="mt-2 text-[color:var(--color-slate)] leading-relaxed">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
