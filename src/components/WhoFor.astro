---
const audiences = [
  {
    title: "Skip-hire operators",
    body: "Running 5–50 vehicles, currently on paper or basic ticketing software.",
  },
  {
    title: "Small-to-medium hauliers",
    body: "Under 50 vehicles — the bottom 90% of the UK's ~57,000 licensed operators.",
  },
  {
    title: "Waste collectors",
    body: "Trade waste, mixed waste, and aggregate sectors. Modern tools at non-enterprise prices.",
  },
];
---

<section id="who" class="bg-[color:var(--color-offwhite)]">
  <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-5">
        <p class="text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-cyan)]">Who it's for</p>
        <h2 class="mt-3 font-[family-name:var(--font-display)] font-extrabold text-3xl md:text-4xl text-[color:var(--color-graphite)] tracking-tight">
          Built for the underserved 90% of UK transport.
        </h2>
        <p class="mt-4 text-[color:var(--color-slate)] text-lg">
          Modern, mobile-first, from £79/month with custom tiers above — well below enterprise incumbents like Access Weighsoft,
          Mandata, and HaulTech, and well above the spreadsheet-and-paper status quo.
        </p>
      </div>
      <div class="md:col-span-7 grid sm:grid-cols-1 gap-4">
        {audiences.map((a) => (
          <div class="rounded-2xl bg-white border border-[color:var(--color-mist)] p-7">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-xl text-[color:var(--color-graphite)]">{a.title}</h3>
            <p class="mt-2 text-[color:var(--color-slate)]">{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
