---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fleetlix — Operations platform for modern waste and haulage firms",
  description = "One Progressive Web App covering driver, yard, and office workflows. DVSA-compliant walk-around checks, real-time dispatch, automated Waste Transfer Notes. Built for skip-hire, haulage, and waste operators in the UK.",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1D21" />
    <link rel="icon" type="image/svg+xml" href="/fleetlix-logo-icon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/space-grotesk/SpaceGrotesk-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter/Inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fleetlix-fonts.css" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
